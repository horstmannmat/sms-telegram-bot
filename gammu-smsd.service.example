[Unit]
Description=SMS daemon for Gammu
Documentation=man:gammu-smsd(1)
After=network-online.target

[Service]
EnvironmentFile=-/etc/sysconfig/gammu-smsd
# GAMMU_USER, GAMMU_GROUP, GAMMU_CONFIG_FILE — see gammu-smsd.sysconfig.example
# Run daemon as non-root user (set user/group in gammu-smsd.sysconfig)
ExecStart=/usr/bin/gammu-smsd --user=${GAMMU_USER} --group=${GAMMU_GROUP} -c ${GAMMU_CONFIG_FILE} --pid=/run/gammu-smsd.pid --daemon
ExecReload=/bin/kill -HUP $MAINPID
ExecStopPost=/bin/rm -f /run/gammu-smsd.pid
Type=forking
PIDFile=/run/gammu-smsd.pid
PrivateTmp=yes

[Install]
# System install: multi-user.target. install.sh --user rewrites to default.target.
WantedBy=multi-user.target
