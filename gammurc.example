# Copy to /etc/gammurc (or another path) and pass it to gammu-smsd -c, or set
# GAMMU_CONFIG_FILE in systemd. Gammu does not load this filename automatically.

[gammu]
device = /dev/ttyUSB0
name = HUAWEI
connection = at

[smsd]
# SMSD service to use, one of FILES, MYSQL, PGSQL, DBI
service = files
# PIN for SIM card
# File (or stderr, syslog, eventlog) where information will be logged
logfile = smsdlog
# Amount of information being logged, each bit mean one level
debuglevel = 0
# gammu-smsd runs: PROGRAM [args...] — then appends the new SMS file path.
# First arg after the script should be config.pkl; the last arg becomes that path.
runonreceive = /path/to/home/sms-telegram-bot/.venv/bin/python /path/to/home/sms-telegram-bot/src/sms.py /path/to/home/sms-telegram-bot/src/config.pkl
# Communication frequency settings
commtimeout = 30
sendtimeout = 30

inboxpath = /path/to/home/sms/inbox/
outboxpath = /path/to/home/sms/outbox/
sentsmspath = /path/to/home/sms/sent/
errorsmspath  = /path/to/home/sms/error/
inboxformat = standard
#outboxformat = detail
